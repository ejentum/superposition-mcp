# Force LF everywhere so the generated artifact (dist/backend.cjs) stays
# byte-identical to the generator output on every platform. Without this,
# autocrlf would rewrite checkouts to CRLF on Windows and the drift test
# would fail on a fresh clone.
* text=auto eol=lf

# The grid carries U+27E8/U+27E9 kets; keep it UTF-8 text with LF, never
# reinterpreted. (text=auto above already covers it; listed for intent.)
*.csv text eol=lf
*.md text eol=lf

# Images are binary: never apply text or line-ending conversion.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
